# Copia este archivo a .env y ajusta los valores.

# --- Entorno ---
# FLASK_ENV=development          # development | production | testing
# FLASK_CONFIG=development       # override explícito (development | production | testing)

# Obligatorio en producción
SECRET_KEY=cambia-esto-en-produccion
PLATFORM_ADMIN_KEY=tu-clave-superadmin-plataforma

# MFA TOTP opcional para panel plataforma (Google Authenticator, etc.)
# Generar secreto: python -c "import pyotp; print(pyotp.random_base32())"
# PLATFORM_ADMIN_TOTP_SECRET=

# Solo desarrollo: usuario admin inicial (requiere DEFAULT_ADMIN_PASSWORD explícita)
# DEFAULT_ADMIN_PASSWORD=tu-clave-dev-segura

# --- Base de datos ---
# SQLite local (desarrollo):
# DATABASE_URL=sqlite:///mantenimiento.db
#
# Neon PostgreSQL (producción):
# DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/dbname?sslmode=require

# --- Logging ---
# LOG_LEVEL=INFO                 # DEBUG | INFO | WARNING | ERROR
# LOG_JSON=true                  # JSON estructurado (auto en producción)

# --- Arranque ---
# RUN_STARTUP_TASKS=true         # Seeds y mantenimiento al arrancar (auto en dev)
# RUN_LEGACY_SCHEMA_MIGRATIONS=false  # ensure_* legacy (solo transición)

# --- Backups Neon ---
# BACKUP_DIR=backups
# BACKUP_RETENTION_DAYS=7
# NEON_PROJECT_ID=               # opcional, para API de Neon
# NEON_API_KEY=                  # opcional, para snapshots vía API

# --- Correo transaccional (temporal: Gmail SMTP) ---
# Activa la verificación en dos pasos en Gmail y crea una contraseña de aplicación.
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=cuenta.temporal@gmail.com
MAIL_PASSWORD=contraseña-de-aplicacion-de-16-caracteres
MAIL_DEFAULT_SENDER=Roustix <cuenta.temporal@gmail.com>
# MAIL_TIMEOUT_SECONDS=10

# Seguridad de verificación de correo
# EMAIL_VERIFICATION_TTL_MINUTES=10
# EMAIL_VERIFICATION_MAX_ATTEMPTS=5
# EMAIL_VERIFICATION_RESEND_SECONDS=60
